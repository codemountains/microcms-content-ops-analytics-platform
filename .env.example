EVENTS_PATH=s3://microcms-content-ops-events/microcms_events/**/*.parquet
AWS_REGION=ap-northeast-1

# Local Floci/ngrok debugging
FLOCI_PORT=4567
FLOCI_LAMBDA_ENDPOINT=http://floci:4566
CARGO_BUILD_JOBS=1
LOCAL_EVENTS_PATH=s3://microcms-content-ops-events-local/microcms_events/**/*.parquet
MICROCMS_WEBHOOK_SECRET=local-webhook-secret
NGROK_AUTHTOKEN=
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Grafana Cloud provisioning
GRAFANA_STACK_URL=
GRAFANA_STACK_SERVICE_ACCOUNT_TOKEN=
QUERY_API_URL=
GRAFANA_DASHBOARD_UID=microcms-content-ops
GRAFANA_FOLDER_UID=
GRAFANA_SKIP_PLUGIN_CHECK=
