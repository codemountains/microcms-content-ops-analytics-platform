      "title": "API Activity",
      "description": "API ごとの event_kind 件数（直近 30 日）。既定は下書き操作 / 公開・更新 / 非公開・再開 / 削除の 4 カテゴリ集約を horizontal stacked bar で表示します。上部の api_activity_view で 14 種の詳細内訳に切り替えられます。",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "indexByName": {
              "api": 0,
              "initial_draft": 1,
              "save_draft": 2,
              "publish_from_draft": 3,
              "initial_publish": 4,
              "update_published": 5,
              "add_draft_to_published": 6,
              "discard_draft_on_published": 7,
              "unpublish_to_draft": 8,
              "unpublish_to_closed": 9,
              "reopen_to_draft": 10,
              "republish_from_closed": 11,
              "delete_draft": 12,
              "delete_published": 13,
              "delete_closed": 14
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "draft_activity",
            "mode": "reduceRow",
            "reduce": {
              "include": [
                "initial_draft",
                "save_draft",
                "add_draft_to_published",
                "discard_draft_on_published"
              ],
              "reducer": "sum"
            },
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "publish_activity",
            "mode": "reduceRow",
            "reduce": {
              "include": [
                "publish_from_draft",
                "initial_publish",
                "update_published",
                "republish_from_closed"
              ],
              "reducer": "sum"
            },
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "unpublish_activity",
            "mode": "reduceRow",
            "reduce": {
              "include": [
                "unpublish_to_draft",
                "unpublish_to_closed",
                "reopen_to_draft"
              ],
              "reducer": "sum"
            },
            "replaceFields": false
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "delete_activity",
            "mode": "reduceRow",
            "reduce": {
              "include": [
                "delete_draft",
                "delete_published",
                "delete_closed"
              ],
              "reducer": "sum"
            },
            "replaceFields": false
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "pattern": "${api_activity_view}"
            }
          }
        }
      ],
      "type": "barchart"
    },
